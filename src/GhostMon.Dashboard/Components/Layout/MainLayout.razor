@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Dense="true" Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="dashboard-brand">GhostMon Dashboard</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="dashboard-brand-subtitle">MudBlazor</MudText>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="dashboard-shell">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
