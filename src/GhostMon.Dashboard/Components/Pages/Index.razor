@page "/"
<PageTitle>GhostMon Dashboard</PageTitle>

<MudStack Spacing="4" Class="dashboard-page">
    <DashboardHero Tag="Live snapshot"
                   Title="GhostMon Dashboard"
                   Subtitle="The list view only renders a light snapshot. Node history is loaded on demand when a node is expanded."
                   RefreshText="Refresh snapshot"
                   RefreshDisabled="@SnapshotLoading"
                   OnRefresh="@LoadSnapshotAsync"
                   CopyText="Copy install command"
                   OnCopy="@CopyInstallCommandAsync"
                   Status="@AgentInstallStatus"
                   Command="@InstallCommand" />

    <DashboardMetrics ClusterLabel="Cluster overview"
                      ClusterValue="@ClusterValue"
                      ClusterDetail="@ClusterDetail"
                      TrafficLabel="Network throughput"
                      TrafficValue="@TrafficValue"
                      TrafficDetail="@TrafficDetail"
                      HealthLabel="Health status"
                      HealthValue="@HealthValue"
                      HealthDetail="@HealthDetail"
                      ToneColor="@HealthColor" />

    <DashboardFilters Title="Filters"
                      Summary="@FilterSummary"
                      Search="@Search"
                      SearchChanged="@OnSearchChanged"
                      Placeholder="Search by node name, group, CPU model, or IP"
                      FilterOptions="@FilterOptions"
                      ToggleText="@ToggleGroupsText"
                      OnToggleCollapse="@ToggleCollapseAll"
                      RefreshText="Manual refresh"
                      OnRefresh="@LoadSnapshotAsync" />

    <NodeBrowser Groups="@VisibleGroups"
                 IsGroupOpen="@IsGroupOpen"
                 IsNodeOpen="@IsNodeOpen"
                 GroupExpandedChanged="@OnGroupExpandedChanged"
                 NodeExpandedChanged="@OnNodeExpandedChanged"
                 AssessNode="@AssessNode"
                 HealthLabel="@HealthLabel"
                 HealthChipColor="@HealthChipColor"
                 NodeName="@NodeName"
                 NodeGroup="@NodeGroup"
                 NodeIdentity="@NodeIdentity"
                 NodeLabel="@NodeLabel"
                 FormatTime="@FormatTime"
                 FormatPercent="@FormatPercent"
                 CurrentRuntime="@CurrentRuntime"
                 BuildSparkline="@BuildSparkline"
                 NodeDetails="@NodeDetails"
                 LoadingDetails="@LoadingDetails" />
</MudStack>
